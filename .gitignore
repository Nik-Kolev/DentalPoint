# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage
/test-results/
/playwright-report/
/e2e/.auth/
/e2e/.data-backup/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env
.env.production

# admin-mutated content — written directly to the server filesystem by the
# admin UI at runtime, never meant to be reset back to a git commit on deploy.
# contact-submissions.json also holds patient PII with a 60-day retention policy —
# must never persist in git history either way.
data/contact-submissions.json
data/home-gallery.json
data/certificates.json
data/gallery-cases.json
data/team.json
data/contact-settings.json
data/pending-changes.json
public/Images/certificates/
public/Images/gallery/
public/Images/owners/
# front/ is the Home Gallery's admin upload dir too, except clinic.jpg (the static,
# hardcoded hero image, never admin-mutated) — keep that one file tracked.
public/Images/front/*
!public/Images/front/clinic.jpg

# e2e-test-run marker — see e2e/global-setup.ts
.e2e-running

# documentation file
DENTALPOINT_DEPLOYMENT_GUIDE.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
